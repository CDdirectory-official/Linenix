# ==============================================================================
# File Path: tools/Makefile
# Description: Cross-Building System tracking Core, Init, FS, MM, Drivers, and Shell.
# ==============================================================================

CC = gcc
CFLAGS = -m32 -c -ffreestanding -O2 -Wall -Wextra
ASM = nasm
LD = ld
LDFLAGS = -m elf_i386 -Ttext 0x1000 --oformat binary

TARGET = ../tzeos_image.bin
BOOT_BIN = boot.bin
KERNEL_BIN = kernel.bin
ENTRY_OBJ = k_entry.o
KERNEL_OBJ = kernel.o

.PHONY: all clean run

all: $(TARGET)

$(BOOT_BIN): ../kernel/boot.asm
	@echo "[ASM] Assembling MBR Stage 1 Boot Sector..."
	@$(ASM) -f bin ../kernel/boot.asm -o $(BOOT_BIN)

$(ENTRY_OBJ): ../kernel/kernel_entry.asm
	@echo "[ASM] Compiling Protected Mode interrupt descriptors..."
	@$(ASM) -f elf32 ../kernel/kernel_entry.asm -o $(ENTRY_OBJ)

# Tracks changes inside the new shell/kshell.h subsystem header
$(KERNEL_OBJ): ../kernel/kernel_graphics.c ../include/vga_io.h ../fs/ramfs.h ../init/setup_init.h ../mm/pmm.h ../drivers/video/font.h ../ipc/mailbox.h ../shell/kshell.h
	@echo "[CC] Transpiling kernel core with Interactive Shell active..."
	@$(CC) $(CFLAGS) ../kernel/kernel_graphics.c -o $(KERNEL_OBJ)

$(KERNEL_BIN): $(ENTRY_OBJ) $(KERNEL_OBJ)
	@echo "[LD] Linking absolute machine addressing segments..."
	@$(LD) $(LDFLAGS) $(ENTRY_OBJ) $(KERNEL_OBJ) -o $(KERNEL_BIN)

$(TARGET): $(BOOT_BIN) $(KERNEL_BIN)
	@echo "[IMG] Injecting binary blocks into clean raw Master Boot Image..."
	@cat $(BOOT_BIN) $(KERNEL_BIN) > $(TARGET)
	@echo "[SUCCESS] Interactive Terminal Command Shell built!"

clean:
	@echo "[CLEAN] Destroying volatile machine artifacts..."
	@rm -f *.o *.bin $(TARGET)

run: all
	@echo "[QEMU] Initiating bare-metal hardware execution matrix..."
	@qemu-system-x86_64 -drive format=raw,file=$(TARGET)
